{
  "name": "siyuan-plugin-knowledge-base",
  "version": "1.0.0",
  "description": "思源笔记 RAG 知识库插件",
  "main": "dist/index.js",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc --noEmit",
    "dev:siyuan": "vite build --watch --mode siyuan",
    "build:siyuan": "vite build --mode siyuan",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.vue",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.0",
    "vue": "^3.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs",
      "sharp"
    ]
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.10",
    "vue-tsc": "^2.0.0"
  }
}
